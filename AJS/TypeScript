⚠️ TYPES ⚠️

let name: string = "Akash"                      // string
let age: number = 25                            // number
let isLoggedIn: boolean = true                  // boolean

let numbers: number[] = [1,2,3]                 // Array
let names: string[] = ["Akash", "John"]


let data: any = "hello"                         // ANY 
data = 10
data = true


let user: {                                     // Object
  name: string
  age: number
}
user = {
  name: "Akash",
  age: 25
}


Basic                                             // Functions
function greet(name: string): string {
  return "Hello " + name
}

Arrow Function
const multiply = (a: number, b: number): number => {
  return a * b
}


type ButtonProps = {                               // React Props with TypeScript
  label: string
}

function Button({ label }: ButtonProps) {
  return <button>{label}</button>
}

